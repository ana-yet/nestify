PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nestify?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Firebase Admin SDK (service account JSON fields)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Admin seed (run: npm run seed:admin)
ADMIN_EMAIL=admin@nestify.com
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=Nestify Admin

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
